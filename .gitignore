# ---------------------------------------------------------------------
# Rust / Cargo build artifacts
# ---------------------------------------------------------------------
/target/
/dist/
**/*.rs.bk
*.pdb

# ---------------------------------------------------------------------
# Compiled binaries (in case the binary is copied out of target/ for
# distribution, smoke testing, or local benchmarks)
# ---------------------------------------------------------------------
/atree
/atree.exe
*.exe
*.so
*.dylib
*.dll
*.a
*.lib
*.o
*.rlib

# ---------------------------------------------------------------------
# Generated outputs from the tool itself (--dot writes to project root
# by default; rendered images and intermediate DOT files don't belong
# in version control).
# ---------------------------------------------------------------------
/atree_map.dot
/atree_map.png
*.dot.png

# ---------------------------------------------------------------------
# Editor and IDE state
# ---------------------------------------------------------------------
.vscode/
.idea/
.fleet/
.zed/
.helix/
.vs/
*.swp
*.swo
*.swn
*~
.#*

# ---------------------------------------------------------------------
# rust-analyzer / tooling
# ---------------------------------------------------------------------
rust-project.json

# ---------------------------------------------------------------------
# Operating system metadata
# ---------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------
# Logs, coverage, profiling
# ---------------------------------------------------------------------
*.log
*.profraw
*.profdata
tarpaulin-report.html
cobertura.xml
flamegraph.svg
perf.data
perf.data.old

# ---------------------------------------------------------------------
# SQLite WAL/shm files (generated by WAL-mode databases)
# ---------------------------------------------------------------------
*.sqlite-shm
*.sqlite-wal
*.sqlite-journal

# ---------------------------------------------------------------------
# Local environment / secrets (never commit these)
# ---------------------------------------------------------------------
.env
.env.local
.env.*.local
.claude/
.gitnexus
